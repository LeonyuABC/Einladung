rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Die Website meldet jeden Browser im Hintergrund anonym bei Firebase an.
    // Der PIN ist ein kleiner Schutz in der Oberfläche, aber keine serverseitige
    // Identitätsprüfung. Teile die Website-Adresse deshalb nur privat.
    function isAnonymousSession() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider == "anonymous";
    }

    match /couples/{coupleId}/{collectionName}/{documentId} {
      allow read, create, update, delete: if
        isAnonymousSession()
        && coupleId == "yaoyu-daria"
        && collectionName in [
          "invitations",
          "plans",
          "diaryEntries",
          "wishlistItems",
          "moods"
        ];
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
